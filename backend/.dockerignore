# Keep the build context small and reproducible.
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local virtualenvs — deps are installed fresh in the image.
.venv/
venv/
env/

# Local secrets & state — NEVER bake into an image.
.env
.env.*
!.env.example
.data/
*.sqlite
*.sqlite3

# Editor / OS noise
.vscode/
.idea/
.DS_Store
*.log

# Tests are not needed at runtime (kept out of the image).
tests/
