# ============================================================================
# LexAegis AI — PRODUCTION backend environment (Gemini + Chroma container)
#
# Copy to your deployment secret store (Railway "Variables", a `.env` mounted at
# /app/.env, etc.). NEVER commit real secrets.
#
#   Railway:   paste each KEY=VALUE into the service Variables tab.
#   Docker:    `docker compose --env-file deployment/production.env -f \
#              docker-compose.production.yml up -d`
#
# Only the values that differ from the development defaults are shown with
# explanations; everything declared in `.env.example` is still accepted.
# ============================================================================

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
APP_NAME=LexAegis AI
ENVIRONMENT=production
DEBUG=false
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
# JSON logs are easier to ship to a log aggregator in production.
LOG_JSON=true
# The Vercel frontend origin(s) allowed to call this API (comma-separated).
# IMPORTANT: use the EXACT origin with NO trailing slash and NO path — it must
# equal the browser's `Origin` header (scheme://host[:port]). A trailing slash
# or a wrong scheme makes preflight OPTIONS return HTTP 400 ("Disallowed CORS").
CORS_ORIGINS=https://your-frontend.vercel.app
# Optional: regex to also allow Vercel PREVIEW deploys, which get a unique host
# per build. Leave empty if you only use the production domain above.
# Example: CORS_ORIGIN_REGEX=https://your-frontend-.*\.vercel\.app
CORS_ORIGIN_REGEX=

# ----------------------------------------------------------------------------
# LLM PROVIDER — production uses the hosted Gemini API (no Ollama required).
# ----------------------------------------------------------------------------
LLM_PROVIDER=gemini

# Understanding stays heuristic by default (its output is advisory and does not
# change retrieval or the answer, so the extra LLM call is pure latency). If you
# find Gemini Flash is fast enough and want LLM-classified intents, set this to
# true — it is safe either way.
USE_LLM_FOR_UNDERSTANDING=false
# Reasoning is the answer generator — keep it on Gemini.
USE_LLM_FOR_REASONING=true
# Gemini applies its own built-in safety; the model-backed input guard is
# optional. Leave true to also run the prompt-based classifier, or false to use
# the fast regex heuristic guard.
ENABLE_LLAMAGUARD=true

# ----------------------------------------------------------------------------
# Gemini  (prefix GEMINI_)
# ----------------------------------------------------------------------------
GEMINI_API_KEY=replace-with-your-google-ai-studio-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODEL=gemini-2.5-flash
GEMINI_REQUEST_TIMEOUT_SECONDS=30
GEMINI_REASONING_TIMEOUT_SECONDS=90
GEMINI_TEMPERATURE=0.1
GEMINI_MAX_TOKENS=1024

# ----------------------------------------------------------------------------
# Supabase Auth  (managed service — NOT containerized)
# ----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_JWT_AUDIENCE=authenticated
# Supabase's modern asymmetric signing keys issue ES256 tokens by default; keep
# ES256 here when you set SUPABASE_JWKS_URL below. HS256 stays for the legacy
# shared-secret path. The JWKS endpoint is your project's:
#   https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_ALGORITHMS=HS256,RS256,ES256
# SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json

# ----------------------------------------------------------------------------
# ChromaDB  — runs as a container; backend talks to it over the Docker network.
# The service name `chroma` resolves on the compose network; the persistent
# volume keeps data across restarts/rebuilds (see docs/DEPLOYMENT_ARCHITECTURE).
# ----------------------------------------------------------------------------
CHROMA_HOST=chroma
CHROMA_PORT=8000
CHROMA_COLLECTION=lexaegis_documents
CHROMA_USE_HTTP_CLIENT=true

# ----------------------------------------------------------------------------
# Embeddings / Reranker — sized for a memory-constrained host (Railway).
#
# These models load into RAM (CPU, fp32) the FIRST time a document is uploaded /
# a question is asked. Pick the row that fits your service's memory limit —
# loading a model bigger than the limit gets the container OOM-KILLED (silent
# restart, no traceback). Approx resident memory ON TOP of the ~0.6 GB base:
#
#   Embedding model            RAM     dim   |  Reranker backend       RAM
#   BAAI/bge-small-en-v1.5    ~0.15GB  384   |  lexical (no model)     0
#   BAAI/bge-base-en-v1.5     ~0.45GB  768   |  bge + bge-reranker-base ~1.1GB
#   BAAI/bge-large-en-v1.5    ~1.3GB   1024  |  bge + bge-reranker-large ~2.2GB
#
# Rule of thumb (base ~0.6GB + embed + rerank, plus headroom):
#   ≤1GB service  -> bge-small + lexical          (DEFAULT below; always safe)
#   ~2GB service  -> bge-small + bge-reranker-base
#   ≥4GB service  -> bge-large  + bge-reranker-large (best quality)
# ----------------------------------------------------------------------------
EMBEDDING_BACKEND=bge
EMBEDDING_DENSE_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_RERANKER_MODEL=BAAI/bge-reranker-base
EMBEDDING_DEVICE=cpu

# ----------------------------------------------------------------------------
# Retrieval — hybrid (dense + BM25) always on. Reranker defaults to the
# zero-model 'lexical' backend so a small instance never OOMs. Switch to 'bge'
# (with EMBEDDING_RERANKER_MODEL above) only if your service has ≥2GB.
# ----------------------------------------------------------------------------
RETRIEVAL_VECTOR_STORE=chroma
RETRIEVAL_RERANKER_BACKEND=lexical
RETRIEVAL_ENABLE_RERANKER=true
RETRIEVAL_ENABLE_COMPRESSION=true

# ----------------------------------------------------------------------------
# Safety — full PII + model guard.  (Groundedness is always enforced.)
# ----------------------------------------------------------------------------
SAFETY_PII_BACKEND=presidio
SAFETY_INPUT_GUARD_BACKEND=llama_guard
SAFETY_ENABLE_INPUT_SAFETY=true
SAFETY_ENABLE_OUTPUT_SAFETY=true
SAFETY_ENABLE_PII_MASKING=true
SAFETY_BLOCK_ON_PII_LEAK=true

# ----------------------------------------------------------------------------
# Caching — semantic cache ON in production (GPTCache).
# ----------------------------------------------------------------------------
OBSERVABILITY_ENABLE_SEMANTIC_CACHE=true
OBSERVABILITY_CACHE_BACKEND=gptcache
OBSERVABILITY_GPTCACHE_DIR=/app/.data/gptcache
OBSERVABILITY_CACHE_SIMILARITY_THRESHOLD=0.92

# ----------------------------------------------------------------------------
# Tracing — configurable. Off by default unless you run a reachable Phoenix
# collector. To enable: set ENABLE_TRACING=true and point OTLP_ENDPOINT at it.
# ----------------------------------------------------------------------------
OBSERVABILITY_ENABLE_TRACING=false
OBSERVABILITY_OTLP_ENDPOINT=http://phoenix:6006/v1/traces
OBSERVABILITY_SERVICE_NAME=lexaegis-ai

# ----------------------------------------------------------------------------
# Evaluation — RAGAS/DeepEval offline harness paths (run as a job, not inline).
#
# LEAVE THESE UNSET on Railway. A report is baked into the image at
# backend/evaluation/results/latest.json and is found automatically, so the
# Evaluation Dashboard works out of the box. Only set EVALUATION_RESULTS_PATH if
# you mount a freshly-generated report at a known ABSOLUTE path (a relative
# "../evaluation/..." value resolves to /evaluation on Railway, which is not in
# the image — that is what previously left the dashboard empty).
# docker-compose overrides these with absolute paths (see docker-compose.production.yml).
# EVALUATION_DATASET_PATH=/app/evaluation/datasets/legal_benchmark.json
# EVALUATION_RESULTS_PATH=/app/evaluation/results/latest.json
