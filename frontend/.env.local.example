# Copy to .env.local
# Backend API base (FastAPI gateway)
NEXT_PUBLIC_API_BASE=http://localhost:8000/api/v1

# Supabase (used for email/password login). Leave blank to use the
# "paste a dev token" login flow instead.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
