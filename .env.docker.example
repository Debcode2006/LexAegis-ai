# ============================================================================
# Docker Compose interpolation file  →  copy to `.env` at the REPO ROOT:
#
#     cp .env.docker.example .env
#
# WHY THIS FILE EXISTS
# Docker Compose substitutes ${VARS} used in docker-compose*.yml from TWO places
# only: (1) your shell environment, and (2) a file named `.env` in the SAME
# directory as the compose file (the repo root). Compose does **NOT** read
# `frontend/.env.local` — that file is a Next.js convention used only when you
# run `next dev` / `next build` natively on the host. That mismatch is why you
# saw "NEXT_PUBLIC_SUPABASE_URL variable is not set" even though
# frontend/.env.local had values.
#
# These values are baked into the frontend bundle at BUILD time, so after
# changing them you must rebuild the frontend:  `... up -d --build frontend`.
#
# (The root `.env` is gitignored — safe for real values.)
# ============================================================================

# --- Frontend (NEXT_PUBLIC_* — public, inlined into the browser bundle) ------

# LOCAL DOCKER: the browser reaches the backend via the published host port.
# (docker-compose.local.yml already hardcodes this; only needed for production.)
NEXT_PUBLIC_API_BASE=http://localhost:8000/api/v1

# Supabase project URL + anon key (same values as frontend/.env.local).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
