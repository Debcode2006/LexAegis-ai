# ============================================================================
# LexAegis AI — Environment configuration
#
# Copy to `.env` (in the backend working directory) and fill in real values:
#     cp .env.example backend/.env
#
# Variables are grouped by subsystem. Phase 1 only requires the App, Supabase,
# and Rate Limit blocks. Remaining blocks are declared so later phases need no
# new variables. Lists are comma-separated.
# ============================================================================

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
APP_NAME=LexAegis AI
# local | development | staging | production
ENVIRONMENT=local
DEBUG=true
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000

# Logging: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
# true -> JSON logs, false -> human-readable logs
LOG_JSON=false

# Comma-separated list of allowed CORS origins (frontend dev server).
CORS_ORIGINS=http://localhost:3000

# ----------------------------------------------------------------------------
# Multi-tenancy
# ----------------------------------------------------------------------------
DEFAULT_TENANT_ID=public
TENANT_HEADER=X-Tenant-ID
ENFORCE_TENANT_ISOLATION=true

# ----------------------------------------------------------------------------
# Agent orchestration  (LangGraph workflow)
# ----------------------------------------------------------------------------
# orchestrator: langgraph (production) | sequential (no LangGraph dependency)
AGENT_ORCHESTRATOR=langgraph
# ----------------------------------------------------------------------------
# LLM PROVIDER SELECTION  — the ONLY switch needed to change inference backend.
#   ollama  -> local development (Qwen3 / Llama3.1 / LlamaGuard3 via Ollama)
#   gemini  -> production        (Gemini 2.5 Flash / Pro via the Google API)
# No application code changes when switching; just change this value (and supply
# the matching backend config below).
# ----------------------------------------------------------------------------
LLM_PROVIDER=ollama
# Use the LLM for these stages (falls back to deterministic heuristics if off
# or if the LLM is unavailable).
# Understanding is heuristic by default: its intent/entity output is advisory
# only (does not change retrieval or the answer), so the LLM call is pure
# latency. Reasoning stays LLM-backed (qwen3).
USE_LLM_FOR_UNDERSTANDING=false
USE_LLM_FOR_REASONING=true
# Master switch for LlamaGuard input safety. false -> fast regex heuristic guard
# (recommended for low-VRAM demos; avoids a ~20s/request Ollama call).
ENABLE_LLAMAGUARD=false

# ----------------------------------------------------------------------------
# Supabase Auth  (prefix SUPABASE_)
# ----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# HS256 verification: paste the project's JWT secret (Settings -> API -> JWT).
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
# RS256 verification (optional): JWKS endpoint. If set, RS256 tokens use this.
SUPABASE_JWKS_URL=
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_ISSUER=
SUPABASE_JWT_ALGORITHMS=HS256,RS256

# ----------------------------------------------------------------------------
# Rate limiting  (prefix RATE_LIMIT_)
# ----------------------------------------------------------------------------
RATE_LIMIT_ENABLED=true
# memory | redis  (redis is implemented in a later phase)
RATE_LIMIT_BACKEND=memory
RATE_LIMIT_REDIS_URL=
RATE_LIMIT_USER_REQUESTS=120
RATE_LIMIT_USER_WINDOW_SECONDS=60
RATE_LIMIT_TENANT_REQUESTS=1200
RATE_LIMIT_TENANT_WINDOW_SECONDS=60
RATE_LIMIT_BURST_MULTIPLIER=1.5

# ----------------------------------------------------------------------------
# Ollama / LLM  (prefix OLLAMA_)  — used when LLM_PROVIDER=ollama (local dev)
# In Docker (docker-compose.local.yml) the backend reaches host Ollama via:
#     OLLAMA_BASE_URL=http://host.docker.internal:11434
# ----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
# Reasoning model. qwen3 (8B) is slow on <=4GB VRAM; for a snappy demo consider
# `ollama pull qwen3:1.7b` and set OLLAMA_PRIMARY_MODEL=qwen3:1.7b.
OLLAMA_PRIMARY_MODEL=qwen3
OLLAMA_FALLBACK_MODEL=llama3.1
# Short default timeout so a hung/missing Ollama fails fast on light stages.
OLLAMA_REQUEST_TIMEOUT_SECONDS=15
# Reasoning gets a longer budget (long generations + model load into VRAM).
OLLAMA_REASONING_TIMEOUT_SECONDS=90
OLLAMA_TEMPERATURE=0.1
OLLAMA_MAX_TOKENS=1024

# ----------------------------------------------------------------------------
# Gemini  (prefix GEMINI_)  — used when LLM_PROVIDER=gemini (production)
# Get an API key at https://aistudio.google.com/apikey
# ----------------------------------------------------------------------------
GEMINI_API_KEY=
# Primary model. gemini-2.5-flash (fast/cheap, recommended) | gemini-2.5-pro
GEMINI_MODEL=gemini-2.5-flash
# Model retried if the primary call fails (transient 5xx / quota).
GEMINI_FALLBACK_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_REQUEST_TIMEOUT_SECONDS=30
GEMINI_REASONING_TIMEOUT_SECONDS=90
GEMINI_TEMPERATURE=0.1
GEMINI_MAX_TOKENS=1024

# ----------------------------------------------------------------------------
# ChromaDB  (prefix CHROMA_)  — consumed in Phase 2
# ----------------------------------------------------------------------------
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=lexaegis_documents
CHROMA_PERSIST_DIRECTORY=./.data/chroma
CHROMA_USE_HTTP_CLIENT=false

# ----------------------------------------------------------------------------
# Embeddings / Reranker  (prefix EMBEDDING_)  — consumed in Phase 2
# ----------------------------------------------------------------------------
EMBEDDING_DENSE_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_RERANKER_MODEL=BAAI/bge-reranker-large
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=16
EMBEDDING_NORMALIZE=true
# backend: bge (production) | hashing (light/local/test, no model download)
EMBEDDING_BACKEND=hashing
# dimension used by the hashing embedder fallback
EMBEDDING_DIMENSION=1024
EMBEDDING_QUERY_INSTRUCTION=Represent this sentence for searching relevant passages:

# ----------------------------------------------------------------------------
# Retrieval tuning  (prefix RETRIEVAL_)  — consumed in Phase 2/3
# ----------------------------------------------------------------------------
RETRIEVAL_DENSE_TOP_K=20
RETRIEVAL_SPARSE_TOP_K=20
RETRIEVAL_RRF_K=60
RETRIEVAL_RERANK_TOP_K=8
RETRIEVAL_FINAL_TOP_K=5
RETRIEVAL_DEDUP_THRESHOLD=0.95
# vector_store: chroma (production) | memory (light/local/test)
RETRIEVAL_VECTOR_STORE=memory
# reranker_backend: bge (production) | lexical (light/local/test)
RETRIEVAL_RERANKER_BACKEND=lexical
RETRIEVAL_ENABLE_RERANKER=true
RETRIEVAL_ENABLE_COMPRESSION=true
RETRIEVAL_CHUNK_MAX_CHARS=1200
RETRIEVAL_CHUNK_OVERLAP_CHARS=150

# ----------------------------------------------------------------------------
# Safety  (prefix SAFETY_)  — consumed in Phase 2
# ----------------------------------------------------------------------------
SAFETY_LLAMA_GUARD_MODEL=llama-guard3
SAFETY_ENABLE_INPUT_SAFETY=true
SAFETY_ENABLE_OUTPUT_SAFETY=true
SAFETY_ENABLE_PII_MASKING=true
SAFETY_PRESIDIO_LANGUAGE=en
SAFETY_PII_ENTITIES=PERSON,EMAIL_ADDRESS,PHONE_NUMBER,LOCATION,IN_PAN,IN_PASSPORT,IN_AADHAAR,ORGANIZATION
# pii_backend: presidio (production) | regex (light/local/test)
SAFETY_PII_BACKEND=regex
# input_guard_backend: llama_guard (production) | heuristic (light/local/test)
SAFETY_INPUT_GUARD_BACKEND=heuristic
SAFETY_PII_SCORE_THRESHOLD=0.5
SAFETY_MIN_CITATION_COVERAGE=0.5
SAFETY_BLOCK_ON_PII_LEAK=true

# ----------------------------------------------------------------------------
# Observability / Caching  (prefix OBSERVABILITY_)  — consumed in Phase 3/4
# ----------------------------------------------------------------------------
OBSERVABILITY_PHOENIX_ENDPOINT=http://localhost:6006
# OTLP collector endpoint Phoenix listens on for traces.
OBSERVABILITY_OTLP_ENDPOINT=http://localhost:6006/v1/traces
OBSERVABILITY_ENABLE_TRACING=true
OBSERVABILITY_SERVICE_NAME=lexaegis-ai
OBSERVABILITY_TRACE_BUFFER_SIZE=200
OBSERVABILITY_GPTCACHE_DIR=./.data/gptcache
OBSERVABILITY_ENABLE_SEMANTIC_CACHE=true
# cache_backend: memory (light/local/test) | gptcache (production) | off
OBSERVABILITY_CACHE_BACKEND=memory
OBSERVABILITY_CACHE_SIMILARITY_THRESHOLD=0.92
OBSERVABILITY_CACHE_MAX_ENTRIES=1000

# ----------------------------------------------------------------------------
# Evaluation
# ----------------------------------------------------------------------------
EVALUATION_DATASET_PATH=../evaluation/datasets/legal_benchmark.json
EVALUATION_RESULTS_PATH=../evaluation/results/latest.json
